# Variables d'environnement — Portfolio Valentin Kahn-Barberon

# URL publique du site (SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://valentin-kahn-barberon.fr

# Email affiché dans le formulaire de contact (fallback mailto)
